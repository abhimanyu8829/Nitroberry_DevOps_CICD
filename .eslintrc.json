{
  "env": {
    "browser": true,
    "node": true,
    "es2021": true
  },
  "extends": ["eslint:recommended"],
  "parserOptions": {
    "ecmaVersion": 12,
    "sourceType": "module"
  },
  "rules": {
    "space-infix-ops": "error",
    "semi": ["error", "always"],
    "quotes": ["error", "single"]
  }
}
